{
  "extends": "@tsconfig/react-native/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@env": [".env.local"]
    },
    "lib": ["es2015", "es2016", "es2017", "es2018", "es2019", "es2020", "esnext", "dom"],
    "target": "es2018",
    "moduleResolution": "node",
    "skipLibCheck": true
  }
}
